[
    {
        "position": "top",
        "height": 36,
        "spacing": 6,
        "margin-top": 0,
        "margin-bottom": 0,
        "margin-left": 0,
        "margin-right": 0,
        "modules-left": [
            "hyprland/workspaces"
        ],
        "modules-center": [],
        "modules-right": [
            "clock",
            "pulseaudio",
            "network",
            "cpu"
        ],
        "hyprland/workspaces": {
            "format": "{id}",
            "on-scroll-up": "hyprctl dispatch workspace e-1",
            "on-scroll-down": "hyprctl dispatch workspace e+1",
            "persistent-workspaces": {
                "*": [
                    1,
                    2,
                    3,
                    4,
                    5
                ]
            },
            "anim-color-1": "#89b4fa",
            "anim-color-2": "#cba6f7",
            "anim-duration": 3,
            "button-radius": 20,
            "button-pad-v": 0,
            "button-pad-h": 4,
            "button-minw": 35,
            "_inverted": false
        },
        "hyprland/window": {
            "format": "{}",
            "max-length": 60,
            "separate-outputs": true
        },
        "clock": {
            "format": "{:%H:%M  |  %A %d %B}",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "timezone": "America/Monterrey",
            "locale": "es_MX.utf8",
            "interval": 1,
            "on-click": "flatpak run com.ml4w.calendar",
            "tooltip": true,
            "_inverted": false
        },
        "cpu": {
            "format": "{usage}% ",
            "tooltip": false,
            "interval": 2
        },
        "memory": {
            "format": "{}% ",
            "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
            "interval": 5
        },
        "temperature": {
            "critical-threshold": 80,
            "format": "{temperatureC}°C {icon}",
            "format-icons": [
                "",
                "",
                ""
            ]
        },
        "network": {
            "format-wifi": "{essid} ({signalStrength}%) ",
            "format-ethernet": "{ipaddr}/{cidr} ",
            "format-disconnected": "Disconnected ⚠",
            "tooltip-format": "{ifname} via {gwaddr} ",
            "on-click": "nm-connection-editor",
            "interval": 5,
            "format-linked": "{ifname} (No IP) ",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "pulseaudio": {
            "format": "{volume}% {icon} {format_source}",
            "format-muted": " {format_source}",
            "format-icons": {
                "headphone": "",
                "hands-free": "",
                "headset": "",
                "phone": "",
                "portable": "",
                "car": "",
                "default": [
                    "",
                    "",
                    ""
                ]
            },
            "on-click": "pavucontrol",
            "scroll-step": 5,
            "format-bluetooth": "{volume}% {icon} {format_source}",
            "format-bluetooth-muted": " {icon} {format_source}",
            "format-source": "{volume}% ",
            "format-source-muted": ""
        },
        "battery": {
            "format": "{capacity}% {icon}",
            "format-icons": [
                "",
                "",
                "",
                "",
                ""
            ],
            "format-charging": "{capacity}% ",
            "format-plugged": "{capacity}% ",
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format-full": "{capacity}% {icon}",
            "format-alt": "{time} {icon}"
        },
        "backlight": {
            "format": "{percent}% {icon}",
            "format-icons": [
                "",
                "",
                "",
                "",
                "",
                "",
                "",
                "",
                ""
            ]
        },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "",
                "deactivated": ""
            }
        },
        "tray": {
            "spacing": 10,
            "icon-size": 18
        },
        "custom/arch": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 20' color='#cba6f7'>󰣇</span>",
            "on-click": "$HOME/.local/bin/vsfetch",
            "tooltip": false,
            "arch-icon-glyph": "󰣇",
            "arch-pad-left": 15,
            "arch-pad-right": 10
        },
        "custom/weather": {
            "format": "{}",
            "exec": "$HOME/.config/waybar/scripts/weather.py",
            "return-type": "json",
            "interval": 3600,
            "tooltip": true,
            "on-click": "flatpak run io.github.amit9838.mousam"
        },
        "custom/updates": {
            "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"󰚰 '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"󰚰 0\",\"class\":\"updated\"}'",
            "return-type": "json",
            "interval": 60,
            "tooltip": false,
            "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
        },
        "custom/swaync": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
            "format-icons": {
                "none": "󰂚",
                "notification": "󰂜",
                "dnd-none": "󰂛",
                "dnd-notification": "󰂛"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true,
            "tooltip": false
        },
        "custom/power": {
            "format": "⏻ ",
            "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
            "tooltip": false,
            "menu": "on-click",
            "menu-file": "$HOME/.config/waybar/power_menu.xml",
            "menu-actions": {
                "shutdown": "shutdown",
                "reboot": "reboot",
                "suspend": "systemctl suspend",
                "hibernate": "systemctl hibernate"
            }
        },
        "custom/settings": {
            "format": "󰒓",
            "on-click": "vswaybar-studio",
            "tooltip": false
        },
        "custom/claudebar": {
            "exec": "claudebar --format '{session_bar} {session_pct}% · {session_reset}'",
            "return-type": "json",
            "interval": 30,
            "signal": 13,
            "tooltip": true,
            "on-click": "xdg-open https://claude.ai/settings/usage"
        },
        "custom/bar-cpu": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type cpu",
            "return-type": "json",
            "interval": 2,
            "tooltip": true
        },
        "custom/bar-mem": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type mem",
            "return-type": "json",
            "interval": 5,
            "tooltip": true
        },
        "custom/bar-vol": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type vol",
            "return-type": "json",
            "interval": 2,
            "tooltip": true,
            "on-click": "pavucontrol"
        },
        "custom/bar-wifi": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type wifi",
            "return-type": "json",
            "interval": 5,
            "tooltip": true,
            "on-click": "nm-connection-editor"
        },
        "battery#bat2": {
            "format": "{icon} {capacity}%",
            "format-icons": [
                "󰁺",
                "󰁼",
                "󰁾",
                "󰂀",
                "󰂂",
                "󰁹"
            ],
            "format-charging": "󰂄 {capacity}%",
            "format-plugged": "󰚥 {capacity}%",
            "states": {
                "warning": 30,
                "critical": 15
            },
            "bat": "BAT2"
        },
        "name": "bar",
        "keyboard-state": {
            "numlock": true,
            "capslock": true,
            "format": "{name} {icon}",
            "format-icons": {
                "locked": "",
                "unlocked": ""
            }
        },
        "sway/mode": {
            "format": "<span style=\"italic\">{}</span>"
        },
        "sway/scratchpad": {
            "format": "{icon} {count}",
            "show-empty": false,
            "format-icons": [
                "",
                ""
            ],
            "tooltip": true,
            "tooltip-format": "{app}: {title}"
        },
        "mpd": {
            "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ⸨{songPosition}|{queueLength}⸩ {volume}% ",
            "format-disconnected": "Disconnected ",
            "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ",
            "unknown-tag": "N/A",
            "interval": 5,
            "consume-icons": {
                "on": " "
            },
            "random-icons": {
                "off": "<span color=\"#f53c3c\"></span> ",
                "on": " "
            },
            "repeat-icons": {
                "on": " "
            },
            "single-icons": {
                "on": "1 "
            },
            "state-icons": {
                "paused": "",
                "playing": ""
            },
            "tooltip-format": "MPD (connected)",
            "tooltip-format-disconnected": "MPD (disconnected)"
        },
        "power-profiles-daemon": {
            "format": "{icon}",
            "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
            "tooltip": true,
            "format-icons": {
                "default": "",
                "performance": "",
                "balanced": "",
                "power-saver": ""
            }
        }
    },
    {
        "name": "dock",
        "position": "bottom",
        "height": 54,
        "spacing": 6,
        "layer": "top",
        "margin-top": 0,
        "margin-bottom": 8,
        "margin-left": 0,
        "margin-right": 0,
        "exclusive": true,
        "passthrough": false,
        "gtk-layer-shell": true,
        "modules-left": [],
        "modules-center": [
            "custom/rofi",
            "custom/terminal",
            "custom/firefox",
            "custom/dolphin",
            "custom/vscode"
        ],
        "modules-right": [],
        "custom/rofi": {
            "format": "󱓟",
            "tooltip": true,
            "on-click": "rofi -show drun",
            "tooltip-format": "App Launcher"
        },
        "custom/terminal": {
            "format": "󰄛",
            "tooltip": true,
            "on-click": "kitty",
            "tooltip-format": "Kitty"
        },
        "custom/firefox": {
            "format": "󰈹",
            "tooltip": true,
            "on-click": "firefox",
            "tooltip-format": "Firefox"
        },
        "custom/dolphin": {
            "format": "󰝰",
            "tooltip": true,
            "on-click": "dolphin",
            "tooltip-format": "Dolphin"
        },
        "custom/vscode": {
            "format": "󰨞",
            "tooltip": true,
            "on-click": "code",
            "tooltip-format": "VS Code"
        }
    }
]